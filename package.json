{
  "name": "yt-downloader-electron",
  "version": "1.0.1",
  "description": "A yt-dlp GUI downloader powered by Electron",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --windows",
    "build:installer": "node build-installer.js",
    "start:installer": "electron ./installer",
    "build:portable": "node scripts/build-portable.js"
  },
  "keywords": [
    "yt-dlp",
    "electron",
    "downloader",
    "youtube",
    "mp3",
    "mp4"
  ],
  "author": "Tabby Neko",
  "license": "ISC",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.tabbyneko.ytdownloader",
    "productName": "YT-DLP Media Downloader",
    "icon": "icon/icon.png",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "icon/icon.png",
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "y2mate.exe"
    },
    "files": [
      "index.html",
      "styles.css",
      "main.js",
      "preload.js",
      "renderer.js",
      "bin-downloader.js",
      "package.json"
    ],
    "asar": true
  }
}